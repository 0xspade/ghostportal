# GhostPortal — Docker Compose Secrets
# Copy this to .env in the project root and fill in your values.
# NEVER commit .env to version control.

# PostgreSQL password (used by docker-compose.yml)
POSTGRES_PASSWORD=change_this_to_a_strong_random_password

# Redis password (used by docker-compose.yml)
REDIS_PASSWORD=change_this_to_a_strong_redis_password
